# Flutterwave Configuration
# Get your API keys from: https://dashboard.flutterwave.com/settings/apis

# ============================================================================
# PRODUCTION KEYS (Use these for live transactions)
# ============================================================================
# Secret Key from Live environment
FLUTTERWAVE_SECRET_KEY=FLWSECK-YOUR_LIVE_SECRET_KEY_HERE-X

# Public Key from Live environment
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-YOUR_LIVE_PUBLIC_KEY_HERE-X

# Secret Hash (used for webhook signature verification)
FLUTTERWAVE_SECRET_HASH=YOUR_SECRET_HASH_HERE

# Encryption Key (for secure data transmission)
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# API Base URL - PRODUCTION (defaults to this if not set)
FLUTTERWAVE_V3_BASE_URL=https://api.flutterwave.com

# ============================================================================
# DEVELOPMENT/TEST KEYS (Use these for testing only - comment out in production)
# ============================================================================
# FLUTTERWAVE_SECRET_KEY=FLWSECK-TEST_YOUR_TEST_SECRET_KEY_HERE-X
# FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-TEST_YOUR_TEST_PUBLIC_KEY_HERE-X
# FLUTTERWAVE_V3_BASE_URL=https://api-dev.flutterwave.com

# ============================================================================
# Important Notes:
# ============================================================================
# - Production API URL: https://api.flutterwave.com
# - Test/Dev API URL: https://api-dev.flutterwave.com (for testing only)
# - Production keys start with: FLWSECK- or FLWPUBK-
# - Test keys include 'TEST' in the prefix: FLWSECK-TEST-
# - NEVER use test/dev URL in production environments
# - The code now defaults to production URL if FLUTTERWAVE_V3_BASE_URL is not set
# - Toggle between Test/Live mode in Flutterwave Dashboard to get respective keys
# - Never commit actual keys to version control
# - Secret hash is required for webhook signature verification
# ============================================================================

# ============================================================================
# Checkout URLs (Generated by API - for reference only)
# ============================================================================
# Production checkout: https://checkout.flutterwave.com/v3/hosted/pay/*
# Testing checkout: https://checkout-v2.dev-flutterwave.com/v3/hosted/pay/*
# ============================================================================
